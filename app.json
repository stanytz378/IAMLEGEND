{
  "name": "IAMLEGEND",
  "description": "ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ ⱽ¹.⁰.⁰ – Advanced WhatsApp Bot by STANY TZ",
  "keywords": ["whatsapp-bot", "baileys", "multi-device", "stanytz", "iamlegend"],
  "repository": "https://github.com/Stanytz378/IAMLEGEND",
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID (get from pairing site)",
      "required": true,
      "value": ""
    },
    "MONGO_URL": {
      "description": "MongoDB connection URL (optional)",
      "required": false,
      "value": ""
    },
    "MYSQL_URL": {
      "description": "MySQL connection URL (optional)",
      "required": false,
      "value": ""
    },
    "POSTGRES_URL": {
      "description": "PostgreSQL connection URL (optional)",
      "required": false,
      "value": ""
    },
    "PREFIXES": {
      "description": "Command prefixes (comma separated)",
      "required": false,
      "value": ".,!,/"
    },
    "PACKNAME": {
      "description": "Sticker pack name",
      "required": false,
      "value": "ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ"
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "required": false,
      "value": "ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ ⱽ¹.⁰.⁰"
    },
    "OWNER_NUMBER": {
      "description": "Bot owner's WhatsApp number (with country code, no +)",
      "required": false,
      "value": "255787069580"
    },
    "COMMAND_MODE": {
      "description": "Bot mode: public/private/groups/inbox/self",
      "required": false,
      "value": "public"
    },
    "BOT_OWNER": {
      "description": "Owner name (for credits)",
      "required": false,
      "value": "STANY TZ"
    },
    "TIMEZONE": {
      "description": "Your timezone (e.g., Africa/Nairobi)",
      "required": false,
      "value": "Africa/Nairobi"
    },
    "REMOVEBG_KEY": {
      "description": "Remove.bg API key (optional)",
      "required": false,
      "value": ""
    }
  },
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" },
    { "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git" }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}