# ____REMOVE THIS LINE AFTER RENAMING sample.env to .env ____

# REQUIRED: Your WhatsApp session ID (get from pairing site)
SESSION_ID=

# OPTIONAL: Remove.bg API key for background removal commands
REMOVEBG_KEY=

# Port used by the built‑in web server (Render/Heroku will override this)
PORT=5000

# OPTIONAL: Phone number for pairing code (if you don't have a session)
# Format: 255787069580 (without + or spaces)
PAIRING_NUMBER=

# ────────────────────────────────────────────────────────────────────────────
# Database Configuration (Optional – leave empty to use JSON file storage)
# ────────────────────────────────────────────────────────────────────────────
# MongoDB connection URI
MONGO_URL=

# PostgreSQL connection URI
POSTGRES_URL=

# MySQL connection URI
MYSQL_URL=

# SQLite database file path (example: ./data/baileys.db)
DB_URL=

# ────────────────────────────────────────────────────────────────────────────
# Bot Settings
# ────────────────────────────────────────────────────────────────────────────
# Command prefixes (comma separated, no spaces)
PREFIXES=.,!,/

# Sticker pack name
PACKNAME=ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ

# Bot display name
BOT_NAME=ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ ⱽ¹.⁰.⁰

# Your WhatsApp number (full international format, no +)
OWNER_NUMBER=255787069580

# Bot mode: public / private / groups / inbox / self
COMMAND_MODE=public

# Maximum number of messages stored per chat (lower = less RAM usage)
MAX_STORE_MESSAGES=20

# Owner name (displayed in info)
BOT_OWNER=STANY TZ

# Timezone (used for logs and time displays)
TIMEZONE=Africa/Nairobi

# ────────────────────────────────────────────────────────────────────────────
# External Links (used in some responses)
# ────────────────────────────────────────────────────────────────────────────
# Your WhatsApp channel link
CHANNEL_LINK=https://whatsapp.com/channel/0029Vb7fzu4EwEjmsD4Tzs1p

# Your YouTube channel name
YT_CHANNEL=STANY TZ

# Newsletter JID (if you have one) – used in forwarded message info
NEWSLETTER_JID=120363404317544295@newsletter